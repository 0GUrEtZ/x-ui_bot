telegram:
  token: "YOUR_BOT_TOKEN_HERE"
  admin_ids:
    - 123456789
  proxy: ""
  api_server: ""
  welcome_file: "https://example.com/welcome.pdf"  # URL to welcome PDF file

# Single panel configuration (legacy, for backward compatibility)
panel:
  url: "https://your-panel-url.com"
  username: "admin"
  password: "your_password"
  limit_ip: 5  # Limit of simultaneous IP connections per user (0 = unlimited)
  traffic_limit_gb: 100  # Traffic limit per user in GB (0 = unlimited)
  backup_days: 7  # Backup database every N days to admins (0 = disabled)

# Multi-panel configuration (recommended for multiple servers)
panels:
  - name: "Main Server"  # Display name for the panel
    url: "https://your-panel-url.com"
    username: "admin"
    password: "your_password"
    enabled: true  # Set to false to temporarily disable this panel
    limit_ip: 5  # Limit of simultaneous IP connections per user (0 = unlimited)
    traffic_limit_gb: 100  # Traffic limit per user in GB (0 = unlimited)
  - name: "Backup Server"
    url: "https://backup-panel-url.com"
    username: "admin"
    password: "backup_password"
    enabled: true
    limit_ip: 3
    traffic_limit_gb: 50

payment:
  bank: "Сбербанк"
  phone_number: "+79001234567"
  instructions_url: ""
  trial_days: 3  # Number of days for trial subscription (0 = disabled)
  prices:
    one_month: 300
    three_month: 800
    six_month: 1500
    one_year: 2800
